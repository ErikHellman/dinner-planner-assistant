# LLM provider configuration for the Pi agent.
# See https://pi.dev/docs/latest/providers for supported providers and models.
PI_PROVIDER=anthropic
PI_MODEL=claude-sonnet-5

# API key for the chosen provider. The variable name follows the
# <PROVIDER>_API_KEY convention (e.g. OPENAI_API_KEY for PI_PROVIDER=openai).
ANTHROPIC_API_KEY=
