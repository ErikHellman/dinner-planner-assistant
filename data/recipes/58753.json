  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Värm ugnen till 200&deg;C (varmluft) eller 225&deg;C (vanlig). Grädda surdegspavé lagom till servering."
    },
    {
      "step": 2,
      "section": null,
      "text": "Fisksoppa: Skär rödlök i tunna klyftor. Slanta morötter."
    },
    {
      "step": 3,
      "section": null,
      "text": "Hetta upp lite olivolja i en rymlig stekgryta. Fräs lök, morötter, pressad vitlök och peppar- och fänkålsmix ca 3 min."
    },
    {
      "step": 4,
      "section": null,
      "text": "Tillsätt tomatpuré, vitvinsvinäger, krossade tomater, vatten och grönsaksbuljong. Koka upp och sjud under lock ca 7 min, tills morötterna mjuknat något. Smaka av med lite salt och nymald svartpeppar."
    },
    {
      "step": 5,
      "section": null,
      "text": "Skär alaska pollock i mindre bitar och krydda med salt. Blanda ner fisken och sjud ca 2 min, tills den är klar."
    },
    {
      "step": 6,
      "section": null,
      "text": "Grovhacka bladpersilja och strö över fisksoppan. Servera med en klick dragonmajonnäs och surdegspavé."
    }
  ],
