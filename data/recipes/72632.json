  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Nudlar: Koka nudlar enligt anvisning på förpackningen. Häll av och spola kallt."
    },
    {
      "step": 2,
      "section": null,
      "text": "Till servering: Rosta alla sesamfrön i en torr och het rymlig stekpanna. Lägg på en tallrik och spara stekpannan."
    },
    {
      "step": 3,
      "section": null,
      "text": "Dressing: Blanda japansk soja, socker, sesamolja, pressad vitlök, sesamfrön och nymald svartpeppar i en skål."
    },
    {
      "step": 4,
      "section": null,
      "text": "Grönsaker: Skala morot. Strimla morot, röd paprika, gul lök och pak choy. Skär shiitake i mindre bitar."
    },
    {
      "step": 5,
      "section": null,
      "text": "Hetta upp rikligt med neutral olja i den använda stekpannan. Fräs morot, lök och shiitake ca 5 min. Krydda med lite salt. Lägg allt i en salladsskål."
    },
    {
      "step": 6,
      "section": null,
      "text": "Lägg ner avhällda nudlar i salladsskålen tillsammans med röd paprika och pak choy. Tillsätt dressingen och blanda väl. Låt gärna allt marineras i ca 5 min."
    },
    {
      "step": 7,
      "section": null,
      "text": "Häll av räkor och strimla röd chili, blanda ner i nudelsalladen. Servera i djupa skålar och toppa med resten av sesamfröna."
    }
  ],
