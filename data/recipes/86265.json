  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Bulgursallad: Koka bulgur enligt anvisningen på förpackningen, men byt ut salt mot kycklingbuljong."
    },
    {
      "step": 2,
      "section": null,
      "text": "Skär tomat, snackgurka och romansallad i mindre bitar. Lägg allt i små skålar eller allt i en salladsskål."
    },
    {
      "step": 3,
      "section": null,
      "text": "Sås: Blanda BBQ-sås med gräddfil i en skål."
    },
    {
      "step": 4,
      "section": null,
      "text": "Fläskkarré: Krydda fläskkarré med persillade, salt och lite nymald svartpeppar. Hetta upp en grill- eller stekpanna på hög värme och tillaga köttet ca 4 min per sida, tills köttet är genomstekt."
    },
    {
      "step": 5,
      "section": null,
      "text": "Bulgursallad: Blanda ner bulgur i salladsskålen och smula över fetaost. Eller servera allt separat."
    },
    {
      "step": 6,
      "section": null,
      "text": "Servera fläskkarré med bulgursallad och sås."
    }
