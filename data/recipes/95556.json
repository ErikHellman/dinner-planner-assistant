  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Värm ugnen till 180&deg;C (varmluft) eller 200&deg;C (vanlig)."
    },
    {
      "step": 2,
      "section": null,
      "text": "Förberedelse: Häll av och skölj svarta bönor. Tärna schalottenlök, röd paprika och tomat."
    },
    {
      "step": 3,
      "section": null,
      "text": "Nötfärschili: Hetta upp olja i en rymlig stekgryta och bryn nötfärs ca 2 min. Tillsätt de tärnade grönsakerna, pressad vitlök, tomatpuré, spiskummin, rökt chilikrydda, salt och nymald svartpeppar, fräs ytterligare ca 2 min."
    },
    {
      "step": 4,
      "section": null,
      "text": "Blanda ner vatten, svarta bönor, socker och oxbuljong. Koka ca 15 min. Smaka av med salt och nymald svartpeppar."
    },
    {
      "step": 5,
      "section": null,
      "text": "Tillaga surdegspavé enligt anvisning på förpackningen."
    },
    {
      "step": 6,
      "section": null,
      "text": "Servera nötfärschili med en klick matyoghurt och surdegspavé."
    }
  ],
