  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Värm ugnen till 225&deg;C (varmluft) eller 250&deg;C (vanlig)."
    },
    {
      "step": 2,
      "section": null,
      "text": "Tostadas: Kvarta tortillabröd. Lägg på en ugnsplåt med bakplåtspapper. Pensla bröden med lite olja. Rosta mitt i ugnen ca 5-7 min, eller tills bröden är krispiga."
    },
    {
      "step": 3,
      "section": null,
      "text": "Mangosalsa: Skala och tärna mango. Finhacka rödlök och koriander. Lägg allt i en skål. Tillsätt pressad saft från en halv lime. Smaka av med salt och chili flakes."
    },
    {
      "step": 4,
      "section": null,
      "text": "Avokadoröra: Skala och lägg avokado i en skål. Mosa sönder med en gaffel. Blanda ner gräddfil, pressad vitlök och salt."
    },
    {
      "step": 5,
      "section": null,
      "text": "Rödkål: Lägg strimlad rödkål i en skål och blanda med pressad limesaft och salt."
    },
    {
      "step": 6,
      "section": null,
      "text": "Häll av räkor. Servera genom att breda lite avokadoröra på de krispiga bröden. Lägg på lite strimlad rödkål, mangosalsa och räkor."
    }
  ],
