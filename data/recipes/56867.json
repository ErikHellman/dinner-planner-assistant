  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Koka matvete enligt anvisning på förpackningen."
    },
    {
      "step": 2,
      "section": null,
      "text": "Sötpotatisgryta: Dela sötpotatis i mindre bitar, ca 2x2 cm. Grovhacka bananschalottenlök och tomat."
    },
    {
      "step": 3,
      "section": null,
      "text": "Hetta upp lite olja i en stekgryta. Fräs lök, sötpotatis och spiskummin ca 3 min på medelvärme."
    },
    {
      "step": 4,
      "section": null,
      "text": "Tillsätt pressad vitlök, grönsaksbuljong, chili flakes (efter smak), tomatsås, coconut cream, vatten och salt. Sjud ca 20 min, tills potatisen är mjuk. Smaka av med lite salt och nymald svartpeppar."
    },
    {
      "step": 5,
      "section": null,
      "text": "Rör ner babyspenat och pressa i saften från &frac12; lime, ta från värmen."
    },
    {
      "step": 6,
      "section": null,
      "text": "Klyfta resten av limen. Toppa sötpotatisgryta med tomat och smulad fetaost. Servera med nykokt matvete och limeklyfta."
    }
  ],
