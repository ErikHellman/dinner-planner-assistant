  "instructions": [
    {
      "step": 1,
      "section": null,
      "text": "Grönsaksgryta: Häll av och skölj kidneybönor. Halvera och skär bort rotfästet på fänkålen. Skär fänkål och morot i cm-stora bitar."
    },
    {
      "step": 2,
      "section": null,
      "text": "Hetta upp olivolja i en stekgryta. Fräs fänkål, morot, cocktailtomater och pressad vitlök ca 5 min."
    },
    {
      "step": 3,
      "section": null,
      "text": "Tillsätt tomatpuré, flytande honung, paprikapulver, spiskummin, chili flakes, vatten och grönsaksbuljong. Låt koka under lock ca 10 min. Lägg ner bönorna när ca 2 min av koktiden återstår. Smaka av grytan med lite salt och nymald svartpeppar."
    },
    {
      "step": 4,
      "section": null,
      "text": "Couscous: Häll couscous i en bunke. Koka upp vatten och grönsaksbuljong. Häll den varma buljongen över couscousen och låt stå ca 10 min. Fluffa grynen med en gaffel."
    },
    {
      "step": 5,
      "section": null,
      "text": "Topping: Finstrimla salladslök. Bryt fetaost i mindre bitar."
    },
    {
      "step": 6,
      "section": null,
      "text": "Strö fetaost och salladslök över grytan. Servera mustig grönsaksgryta med nykokt couscous."
    }
  ],
