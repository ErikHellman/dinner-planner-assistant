.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Editor state
.txt/

# Env
.env
.env.*
!.env.example
!.env.test

# Agent session logs
/data/sessions/

# Willys session cache (contains auth cookies)
/data/willys/

# Latest aggregated shopping list (written by "recipes aggregate" / recipe_aggregate)
/data/plans/

# Settings written from the Inställningar tab, and the key its secrets are
# encrypted with (both machine-local, never committed)
/data/settings.json
/data/settings.key

# Atomic-write temp files (recipe harvest writes tmp+rename; a crash mid-write can leave these)
/data/recipes/**/*.tmp

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
